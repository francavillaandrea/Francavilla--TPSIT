{
    // =========================
    // TEMA & INTERFACCIA
    // =========================
    "workbench.colorTheme": "One Monokai",
    "workbench.iconTheme": "vscode-icons",
    "workbench.startupEditor": "none",
    "workbench.editor.enablePreview": false,
    "workbench.editor.tabCloseButton": "right",
    "workbench.editor.showTabs": "multiple",
    "workbench.activityBar.visible": true,
    "workbench.statusBar.visible": true,
    "workbench.sideBar.location": "left",
    "workbench.panel.defaultLocation": "bottom",
    "workbench.list.smoothScrolling": true,
    "workbench.list.defaultFindMode": "highlight",
    "workbench.list.typeNavigationMode": "highlight",
    "workbench.tree.renderIndentGuides": "always",
    "workbench.editor.animateTabs": true,
    "workbench.editor.openSideBySideDirection": "right",
    "workbench.editor.smoothScrolling": true,
    "workbench.tree.indent": 20,
    "workbench.sideBar.experimental.useSidebarAnimations": true,
    "workbench.panel.experimental.usePanelAnimations": true,
    "workbench.menuBarVisibility": "toggle",
    // =========================
    // FILE SYSTEM
    // =========================
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 800,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.exclude": {
        "**/.git": true,
        "**/.DS_Store": true,
        "**/node_modules": true
    },
    // =========================
    // EDITOR
    // =========================
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.wordWrap": "on",
    "editor.smoothScrolling": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorBlinking": "phase",
    "editor.renderWhitespace": "boundary",
    "editor.minimap.enabled": true,
    "editor.minimap.renderCharacters": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "editor.scrollBeyondLastLine": true,
    "editor.foldingHighlight": true,
    "editor.stickyScroll.enabled": true,
    "editor.hover.enabled": true,
    "editor.hover.delay": 100,
    "editor.hover.sticky": true,
    "editor.renderLineHighlight": "all",
    "editor.renderIndentGuides": true,
    "editor.folding": true,
    "editor.foldingStrategy": "auto",
    // =========================
    // LIVE SERVER (OTTIMIZZATO)
    // =========================
    "liveServer.settings.port": 6967,
    "liveServer.settings.host": "127.0.0.1",
    "liveServer.settings.root": "/",
    "liveServer.settings.ChromeDebuggingAttachment": true,
    "liveServer.settings.NoBrowser": false,
    "liveServer.settings.fullReload": true,
    "liveServer.settings.wait": 50,
    "liveServer.settings.ignoreFiles": [
        "**/.vscode/**",
        "**/.git/**",
        "**/node_modules/**",
        "**/*.map"
    ],
    "liveServer.settings.AdvanceCustomBrowserCmdLine": "",
    // =========================
    // HTML / CSS / JS
    // =========================
    "html.format.indentInnerHtml": true,
    "html.format.wrapLineLength": 120,
    "html.autoClosingTags": true,
    "html.autoCreateQuotes": true,
    "css.validate": true,
    "javascript.validate.enable": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "emmet.triggerExpansionOnTab": true,
    "emmet.showExpandedAbbreviation": "always",
    // =========================
    // TERMINALE (CMD)
    // =========================
    "terminal.integrated.defaultProfile.windows": "Command Prompt",
    "terminal.integrated.scrollback": 5000,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorSmoothCaretAnimation": true,
    // =========================
    // QUALITY OF LIFE
    // =========================
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "breadcrumbs.enabled": true,
    "window.zoomLevel": 0
}
